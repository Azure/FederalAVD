# customer/ is entirely local to each deployment -- nothing in it is tracked
# except the top-level README.md and .gitkeep placeholder files that preserve
# the directory skeleton when the repo is cloned. Example/starter content
# lives in customer-examples/ at the repo root (fully tracked).
customer/artifacts/**
!customer/artifacts/.gitkeep
!customer/artifacts/README.md

customer/parameters/**
!customer/parameters/README.md
!customer/parameters/**/
!customer/parameters/**/.gitkeep