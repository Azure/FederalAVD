{
    // =========================================================================
    // FederalAVD - PoC / Starter Host Pool Parameter File
    // =========================================================================
    //
    // Scenario: existing VNet, marketplace image (Win11 M365), Entra ID join,
    //           pooled DepthFirst, AzureFiles Standard FSLogix, no CMK,
    //           monitoring enabled, PowerShell deployment.
    //
    // Key defaults used (not specified here -- change only if needed):
    //   hostPoolType           : Pooled DepthFirst
    //   virtualMachineSize     : Standard_D4ads_v5  (4 vCPUs, 16 GB)
    //   availability           : AvailabilityZones
    //   fslogixStorageService  : AzureFiles Standard (single storage account)
    //   fslogixStorageRedundancy: LocallyRedundant
    //   enableMonitoring       : true
    //   encryptionAtHost       : true  *requires EncryptionAtHost feature registration*
    //   image                  : Win11 multi-session + M365 Apps (marketplace)
    //
    // INSTRUCTIONS
    // ------------
    // 1. Copy this file:
    //      New-Item -ItemType Directory -Force customer\parameters\hostpools | Out-Null
    //      Copy-Item customer-examples\parameters\hostpools\poc.hostpool.parameters.json `
    //                customer\parameters\hostpools\myfirstpool.parameters.json
    //
    // 2. Change every value marked  TODO  below.
    //
    // 3. Verify the default VM size is available in your target region:
    //      .\tools\Test-AvdVmSize.ps1 -Location '<your-region>' -SessionHostCount 3
    //
    // 4. Deploy (credentials are @secure() - collect them at runtime, NOT in this file):
    //      $p    = 'myfirstpool.parameters.json'
    //      $user = Read-Host 'Session host local admin username'
    //      $pass = Read-Host 'Session host local admin password' -AsSecureString
    //      New-AzDeployment -Location '<your-region>' `
    //          -Name ([IO.Path]::GetFileNameWithoutExtension($p)) `
    //          -TemplateFile '.\deployments\hostpools\hostpool.json' `
    //          -TemplateParameterFile ".\customer\parameters\hostpools\$p" `
    //          -virtualMachineAdminUserName $user `
    //          -virtualMachineAdminPassword $pass `
    //          -Verbose
    //
    // NOTE: Do not add a "timeStamp" parameter here. It must auto-generate on
    //       each deployment run. If you export a parameter file from the Portal
    //       or Template Spec UI, remove "timeStamp" before saving.
    //
    // For the full step-by-step guide see:
    //   docs/quick-start.md#step-4-deploy-host-pool
    // =========================================================================

    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {

        // -- Identity ---------------------------------------------------------
        //    EntraId = Entra-joined (cloud-only). No domain join credentials needed.
        //    For hybrid (ADDS), change to "ActiveDirectoryDomainServices" and add:
        //    domainName, domainJoinUserPrincipalName, domainJoinUserPassword.
        "identitySolution": {
            "value": "EntraId"
        },

        // -- Deployment identifier --------------------------------------------
        // TODO: Short prefix for this deployment (max 9 chars). Used in resource names.
        //       Example: "test", "dev", "pilot"
        "identifier": {
            "value": "dev"
        },

        // -- Session hosts ----------------------------------------------------
        // TODO: Change to match your naming convention (max 14 chars).
        "virtualMachineNamePrefix": {
            "value": "avddev"
        },

        "sessionHostCount": {
            "value": 3
        },

        // TODO: Replace with the full resource ID of your session host subnet.
        //       Azure Portal -> Virtual Networks -> [vnet] -> Subnets -> [subnet] -> Resource ID
        //       Or run: (Get-AzVirtualNetworkSubnetConfig -Name '<subnet>' `
        //                   -VirtualNetwork (Get-AzVirtualNetwork -Name '<vnet>' `
        //                   -ResourceGroupName '<rg>')).Id
        "virtualMachineSubnetResourceId": {
            "value": "/subscriptions/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/resourceGroups/rg-networking/providers/Microsoft.Network/virtualNetworks/vnet-hub/subnets/snet-avd-hosts"
        },

        // -- FSLogix profile storage ------------------------------------------
        //    Deploys one AzureFiles Standard storage account (20,000 IOPS max).
        //    Default shard = None (single account). Default redundancy = LocallyRedundant.
        "deployFSLogixStorage": {
            "value": true
        },

        // -- AVD app group assignment -----------------------------------------
        // TODO: Replace with your Entra security group object ID and display name.
        //       id   = object ID (GUID) of the Entra group
        //       name = display name (informational only, not enforced)
        "appGroupSecurityGroups": {
            "value": [
                {
                    "id": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
                    "name": "sg-avd-users"
                }
            ]
        }
    }
}
