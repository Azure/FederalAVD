{
    "$schema": "https://schema.management.azure.com/schemas/2021-09-09/uiFormDefinition.schema.json",
    "view": {
        "kind": "Form",
        "properties": {
            "title": "M365 Route Table Updater",
            "steps": [
                {
                    "name": "basics",
                    "label": "Deployment Basics",
                    "elements": [
                        {
                            "name": "infoBox1",
                            "type": "Microsoft.Common.TextBlock",
                            "visible": true,
                            "options": {
                                "text": "Deploys an Azure Automation Account with a PowerShell runbook that automatically updates an Azure Route Table with current Microsoft 365 IP ranges. Routes managed by this add-on use an instance-specific prefix (e.g. 'M365-DoD-') and are reconciled on each run. All other routes in the table are left untouched."
                            }
                        },
                        {
                            "name": "resourceScope",
                            "type": "Microsoft.Common.ResourceScope",
                            "subscription": {
                                "resourceProviders": [
                                    "Microsoft.Automation/automationAccounts"
                                ]
                            },
                            "resourceGroup": {
                                "allowExisting": true
                            },
                            "location": {
                                "label": "Region",
                                "toolTip": "Select the Azure region for the automation account.",
                                "resourceTypes": [
                                    "Microsoft.Automation/automationAccounts"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "routeTable",
                    "label": "Route Table",
                    "elements": [
                        {
                            "name": "infoRouteTable",
                            "type": "Microsoft.Common.TextBlock",
                            "visible": true,
                            "options": {
                                "text": "Select the route table to manage. The Automation Account managed identity will be granted Network Contributor on the route table resource group."
                            }
                        },
                        {
                            "name": "routeTable",
                            "type": "Microsoft.Solutions.ResourceSelector",
                            "label": "Select Route Table",
                            "resourceType": "Microsoft.Network/routeTables",
                            "options": {
                                "filter": {
                                    "subscription": "onBasics",
                                    "location": "onBasics"
                                }
                            }
                        },
                        {
                            "name": "m365EndpointInstance",
                            "type": "Microsoft.Common.DropDown",
                            "label": "Microsoft 365 Environment",
                            "defaultValue": "Microsoft 365 Worldwide (+GCC)",
                            "toolTip": "Select the Microsoft 365 cloud environment whose IP ranges should be downloaded.",
                            "constraints": {
                                "required": true,
                                "allowedValues": [
                                    {
                                        "label": "Microsoft 365 Worldwide (+GCC)",
                                        "value": "worldwide"
                                    },
                                    {
                                        "label": "Microsoft 365 U.S. Government GCC High",
                                        "value": "usgovgcchigh"
                                    },
                                    {
                                        "label": "Microsoft 365 U.S. Government DoD",
                                        "value": "usgovdod"
                                    },
                                    {
                                        "label": "Microsoft 365 operated by 21 Vianet",
                                        "value": "china"
                                    }
                                ]
                            }
                        },
                        {
                            "name": "scheduleFrequencyHours",
                            "type": "Microsoft.Common.DropDown",
                            "label": "Update Frequency (hours)",
                            "defaultValue": "Every 8 hours",
                            "toolTip": "How often the runbook checks for updated M365 IP ranges. The M365 endpoint API also provides a version check, so unchanged data will not result in a route table PUT.",
                            "constraints": {
                                "required": true,
                                "allowedValues": [
                                    {
                                        "label": "Every 1 hour",
                                        "value": 1
                                    },
                                    {
                                        "label": "Every 2 hours",
                                        "value": 2
                                    },
                                    {
                                        "label": "Every 4 hours",
                                        "value": 4
                                    },
                                    {
                                        "label": "Every 8 hours",
                                        "value": 8
                                    },
                                    {
                                        "label": "Every 12 hours",
                                        "value": 12
                                    },
                                    {
                                        "label": "Every 24 hours",
                                        "value": 24
                                    }
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "monitoring",
                    "label": "Monitoring",
                    "elements": [
                        {
                            "name": "enableMonitoring",
                            "type": "Microsoft.Common.CheckBox",
                            "label": "Enable Monitoring",
                            "defaultValue": true,
                            "toolTip": "Send Automation Account job logs and metrics to a Log Analytics Workspace."
                        },
                        {
                            "name": "logAnalyticsWorkspace",
                            "type": "Microsoft.Solutions.ResourceSelector",
                            "label": "Log Analytics Workspace",
                            "resourceType": "Microsoft.OperationalInsights/workspaces",                            
                            "visible": "[steps('monitoring').enableMonitoring]"
                        }
                    ]
                },
                {
                    "name": "advanced",
                    "label": "Advanced",
                    "elements": [
                        {
                            "name": "infoBox1",
                            "type": "Microsoft.Common.InfoBox",
                            "options": {
                                "style": "Info",
                                "text": "Use this page to override resource names or provide a custom runbook URI. Leave all fields blank to use automatically derived names and the default public GitHub URI."
                            }
                        },
                        {
                            "name": "namingSection",
                            "type": "Microsoft.Common.Section",
                            "label": "Resource Name Overrides",
                            "elements": [
                                {
                                    "name": "namingInfo",
                                    "type": "Microsoft.Common.InfoBox",
                                    "options": {
                                        "style": "Info",
                                        "text": "Leave blank to use a name automatically derived from the route table resource ID."
                                    }
                                },
                                {
                                    "name": "automationAccountNameOverride",
                                    "type": "Microsoft.Common.TextBox",
                                    "label": "Automation Account Name",
                                    "placeholder": "aa-m365routes-prod-eus2",
                                    "toolTip": "Optional. Explicit name for the Automation Account. Must be 6-128 characters, alphanumeric and hyphens.",
                                    "constraints": {
                                        "required": false,
                                        "validations": [
                                            {
                                                "regex": "^$|^[a-zA-Z0-9-]{6,128}$",
                                                "message": "Automation Account name must be 6-128 characters, alphanumeric and hyphens only."
                                            }
                                        ]
                                    }
                                }
                            ]
                        },
                        {
                            "name": "runbookSection",
                            "type": "Microsoft.Common.Section",
                            "label": "Runbook Content",
                            "elements": [
                                {
                                    "name": "runbookInfo",
                                    "type": "Microsoft.Common.InfoBox",
                                    "options": {
                                        "style": "Info",
                                        "text": "By default the runbook is downloaded from the public FederalAVD GitHub repository at deployment time. For air-gapped or private deployments, host the runbook file internally and provide the URI here."
                                    }
                                },
                                {
                                    "name": "runbookContentUri",
                                    "type": "Microsoft.Common.TextBox",
                                    "label": "Runbook Content URI",
                                    "defaultValue": "",
                                    "placeholder": "https://raw.githubusercontent.com/Azure/FederalAVD/main/deployments/add-ons/updateRouteTableWithM365Routes/runbook/run.ps1",
                                    "toolTip": "Optional. URI of the runbook PS1 file. Leave blank to use the default GitHub raw URI.",
                                    "constraints": {
                                        "required": false,
                                        "validations": [
                                            {
                                                "regex": "^$|^https?://.+\\.ps1$",
                                                "message": "Must be a valid HTTPS URI ending in .ps1, or leave blank for the default."
                                            }
                                        ]
                                    }
                                }
                            ]
                        }
                    ]
                },
                {
                    "name": "tags",
                    "label": "Tags",
                    "elements": [
                        {
                            "name": "tags",
                            "type": "Microsoft.Common.TagsByResource",
                            "resources": [
                                "Microsoft.Automation/automationAccounts"
                            ]
                        }
                    ]
                }
            ]
        },
        "outputs": {
            "parameters": {
                "automationAccountNameOverride": "[steps('advanced').namingSection.automationAccountNameOverride]",
                "routeTableResourceId": "[steps('routeTable').routeTable.id]",
                "m365EndpointInstance": "[steps('routeTable').m365EndpointInstance]",
                "scheduleFrequencyHours": "[steps('routeTable').scheduleFrequencyHours]",
                "logAnalyticsWorkspaceResourceId": "[if(steps('monitoring').enableMonitoring, steps('monitoring').logAnalyticsWorkspace.id, '')]",                
                "runbookContentUri": "[if(empty(steps('advanced').runbookSection.runbookContentUri), 'https://raw.githubusercontent.com/Azure/FederalAVD/main/deployments/add-ons/updateRouteTableWithM365Routes/runbook/run.ps1', steps('advanced').runbookSection.runbookContentUri)]",
                "tags": "[steps('tags').tags]"
            },
            "kind": "ResourceGroup",
            "location": "[steps('basics').resourceScope.location.name]",
            "resourceGroupId": "[steps('basics').resourceScope.resourceGroup.id]"
        }
    }
}