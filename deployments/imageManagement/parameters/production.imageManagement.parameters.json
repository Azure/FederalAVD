{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "nameConvResTypeAtEnd": {
      "value": false
    },
    "deployArtifactsStorageAccount": {
      "value": true
    },
    "deployBuildLogsStorageAccount": {
      "value": true
    },
    "storageNetworkAccess": {
      "value": "PublicEndpoint"
    },
    "storageAllowSharedKeyAccess": {
      "value": false
    },
    "storagePermittedIPs": {
      "value": [
        "<ipAddressOrCidr>"
      ]
    },
    "keyManagementStorageAccount": {
      "value": "CustomerManaged"
    },
    "encryptionKeyVaultResourceId": {
      "value": "/subscriptions/<subscriptionId>/resourceGroups/<keyVaultResourceGroup>/providers/Microsoft.KeyVault/vaults/<keyVaultName>"
    },
    "keyExpirationInDays": {
      "value": 180
    },
    "remoteLocation": {
      "value": "<secondaryRegion>"
    },
    "tags": {
      "value": {
        "Microsoft.Resources/resourceGroups": {
          "Environment": "Production",
          "WorkloadName": "AVD Image Management"
        },
        "Microsoft.Compute/galleries": {
          "Environment": "Production"
        },
        "Microsoft.Storage/storageAccounts": {
          "Environment": "Production",
          "DataClassification": "Internal"
        },
        "Microsoft.ManagedIdentity/userAssignedIdentities": {
          "Environment": "Production"
        }
      }
    }
  }
}
