{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "nameConvResTypeAtEnd": {
      "value": false
    },
    "deployArtifactsStorageAccount": {
      "value": true
    },
    "deployBuildLogsStorageAccount": {
      "value": true
    },
    "storageNetworkAccess": {
      "value": "ServiceEndpoint"
    },
    "storageAllowSharedKeyAccess": {
      "value": false
    },
    "storageServiceEndpointSubnetResourceIds": {
      "value": [
        "/subscriptions/<subscriptionId>/resourceGroups/<networkResourceGroup>/providers/Microsoft.Network/virtualNetworks/<vnetName>/subnets/<subnetName>"
      ]
    },
    "tags": {
      "value": {}
    }
  }
}
