{
    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {

        // ── Deployment ─────────────────────────────────────────────────────────
        "location": {
            "value": "usgovvirginia"
        },
        "deploymentPrefix": {
            "value": "avd"
        },

        // ── Required Existing Resources ────────────────────────────────────────
        //    These values come from the imageManagement deployment outputs.
        "computeGalleryResourceId": {
            "value": "/subscriptions/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/resourceGroups/rg-avd-image-management-usgva/providers/Microsoft.Compute/galleries/gal_avd_image_management_usgva"
        },
        "artifactsContainerUri": {
            "value": "https://saimageassetsxxxxxxxxxx.blob.core.usgovcloudapi.net/artifacts"
        },
        "userAssignedIdentityResourceId": {
            "value": "/subscriptions/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/resourceGroups/rg-avd-image-management-usgva/providers/Microsoft.ManagedIdentity/userAssignedIdentities/uai-avd-image-management-usgva"
        },
        "subnetResourceId": {
            "value": "/subscriptions/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/resourceGroups/rg-avd-networking-usgva/providers/Microsoft.Network/virtualNetworks/vnet-avd-usgva/subnets/snet-avd-imagebuilds"
        },

        // ── VM Properties ──────────────────────────────────────────────────────
        "vmSize": {
            "value": "Standard_D4ads_v6"
        },
        "encryptionAtHost": {
            "value": true
        },

        // ── Source Marketplace Image ───────────────────────────────────────────
        "mpPublisher": {
            "value": "MicrosoftWindowsDesktop"
        },
        "mpOffer": {
            "value": "windows-11"
        },
        "mpSku": {
            "value": "win11-24h2-avd"
        },

        // ── Software Installations ─────────────────────────────────────────────
        "installFsLogix": {
            "value": true
        },
        "office365AppsToInstall": {
            "value": [ "Excel", "OneNote", "Outlook", "PowerPoint", "Word" ]
        },
        "installOneDrive": {
            "value": true
        },
        "installTeams": {
            "value": true
        },
        "teamsCloudType": {
            "value": "GCCH"
        },

        // ── Image Customizations ───────────────────────────────────────────────
        "applyWindowsDesktopOptimizations": {
            "value": true
        },
        "customizations": {
            "value": []
        },

        // ── Bloatware Removal ──────────────────────────────────────────────────
        "appsToRemove": {
            "value": [
                "Microsoft.BingNews",
                "Microsoft.BingSearch",
                "Microsoft.BingWeather",
                "Microsoft.GamingApp",
                "Microsoft.GetHelp",
                "Microsoft.Getstarted",
                "Microsoft.MicrosoftSolitaireCollection",
                "Microsoft.OutlookForWindows",
                "Microsoft.People",
                "Microsoft.PowerAutomateDesktop",
                "Microsoft.SkypeApp",
                "Microsoft.Todos",
                "Microsoft.WindowsAlarms",
                "Microsoft.WindowsCamera",
                "microsoft.windowscommunicationsapps",
                "Microsoft.WindowsFeedbackHub",
                "Microsoft.WindowsMaps",
                "Microsoft.WindowsSoundRecorder",
                "Microsoft.Xbox.TCUI",
                "Microsoft.XboxApp",
                "Microsoft.XboxGameOverlay",
                "Microsoft.XboxGamingOverlay",
                "Microsoft.XboxIdentityProvider",
                "Microsoft.YourPhone",
                "Microsoft.ZuneMusic",
                "Microsoft.ZuneVideo"
            ]
        },
        "cleanupDesktop": {
            "value": true
        },

        // ── Disable Software Update Channels ───────────────────────────────────
        //    All channels locked — updates managed via WSUS / Intune.
        "disableSoftwareUpdates": {
            "value": [
                "disableWindowsUpdate",
                "disableM365Update",
                "disableTeamsUpdate",
                "disableOneDriveUpdate",
                "disableEdgeUpdate",
                "disableWebView2Update",
                "disableStoreAutoUpdate"
            ]
        },

        // ── Windows Updates (applied during build via WSUS) ────────────────────
        "installUpdates": {
            "value": true
        },
        "updateService": {
            "value": "WSUS"
        },
        "wsusServer": {
            "value": "https://wsus.corp.contoso.gov:8531"
        },

        // ── Build Logs ─────────────────────────────────────────────────────────
        "collectCustomizationLogs": {
            "value": true
        },
        "existingLogStorageAccountResourceId": {
            "value": "/subscriptions/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/resourceGroups/rg-avd-image-management-usgva/providers/Microsoft.Storage/storageAccounts/saimagelogsxxxxxxxxxx"
        },

        // ── Image Definition (use existing) ────────────────────────────────────
        //    To create a new definition instead, remove imageDefinitionResourceId
        //    and supply imageDefinitionPublisher/Offer/Sku.
        "imageDefinitionResourceId": {
            "value": "/subscriptions/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/resourceGroups/rg-avd-image-management-usgva/providers/Microsoft.Compute/galleries/gal_avd_image_management_usgva/images/win11-24h2-avd-gcch"
        },

        // ── Image Version ──────────────────────────────────────────────────────
        "imageVersionDefaultReplicaCount": {
            "value": 2
        },
        "imageVersionDefaultStorageAccountType": {
            "value": "Standard_LRS"
        },
        "imageVersionEOLinDays": {
            "value": 180
        }
    }
}
